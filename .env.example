#
# Local development environment. Copy to `.env` (git-ignored). None of these are
# required to run standalone on the LAN — the app degrades gracefully when the
# OpenMasjidOS Fabric, the tunnel, Stripe and SMTP are all absent (CLAUDE.md §6).

# Web port the server listens on (container port; the platform maps a host port).
PORT=8080

# Data volume: SQLite DB (WAL), attachments, and generated report/transcript PDFs.
# In dev this defaults to ./packages/server/data when unset.
DATA_DIR=

# ── OpenMasjidOS Fabric (injected by the platform in production) ──────────────
# Read every process start; NEVER persisted to the data volume (restore-resilient).
# Leave blank for standalone LAN dev. Simulate the Cloudflare tunnel origin locally
# by sending a request header `cf-ray: dev` (exercises the admin-LAN-only policy).
OPENMASJID_BASE_URL=
OPENMASJID_APP_ID=
OPENMASJID_APP_SECRET=
OPENMASJID_PUBLIC_URL=

# ── Stripe (fetched over the Fabric in production; optional local override) ───
# The secret key is read server-side only and never sent to the browser or logged.
STRIPE_ACCOUNT=
CURRENCY=usd
SCHOOL_NAME=
